DATABASE_URL=postgresql://postgres:your-password@localhost:5432/smart_grading
SECRET_KEY=your-secret-key-here
OCR_ENGINE=easyocr
UPLOAD_DIR=./uploads
REPORT_DIR=./reports
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,txt,csv
GEMINI_API_KEY=isi-dengan-api-key-dari-aistudio.google.com
GEMINI_MODEL=gemini-3.5-flash

# Kosongkan kalau poppler sudah terdeteksi otomatis. Isi kalau di Windows PATH tidak terbaca.
# Contoh Windows: POPPLER_PATH=C:\poppler\Library\bin
POPPLER_PATH=
